# Copy to .env and adjust. Everything has sensible local defaults.

# Ollama (local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:32b

# YLE API — optional. Register your own key at https://developer.yle.fi/
# Without it, reading mode still works via pasted article text.
YLE_APP_ID=
YLE_APP_KEY=

# Voikko: leave empty to use the system dictionary. If libvoikko can't find
# one, point this at a directory containing a Voikko dictionary (see README).
VOIKKO_DICT_PATH=

USER_NAME=Eduardo
LEVEL=B1
DAILY_GOAL_MINUTES=20
